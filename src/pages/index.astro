---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const featuredPosts = sortedPosts.filter(p => p.data.featured);
const recentPosts = sortedPosts.slice(0, 6);

const topics = [
  {
    id: 'cybersecurity',
    icon: '◉',
    title: 'Cybersecurity',
    desc: 'Sicurezza offensiva e difensiva, threat intelligence, zero trust, vulnerability research e il panorama delle minacce digitali.',
    color: '#f87171',
    count: allPosts.filter(p => p.data.category === 'cybersecurity').length
  },
  {
    id: 'ai',
    icon: '◎',
    title: 'Intelligenza Artificiale',
    desc: 'LLM, machine learning, ragionamento automatico, allineamento e le implicazioni etiche dell\'AI nel mondo reale.',
    color: '#a78bfa',
    count: allPosts.filter(p => p.data.category === 'ai').length
  },
  {
    id: 'domotica',
    icon: '◌',
    title: 'Domotica & IoT',
    desc: 'Smart home, protocolli aperti, Home Assistant, automazioni, privacy locale e l\'ecosistema dei dispositivi connessi.',
    color: '#63cab7',
    count: allPosts.filter(p => p.data.category === 'domotica').length
  },
  {
    id: 'tech',
    icon: '◈',
    title: 'Tech',
    desc: 'Hardware, software, architetture di sistema, open source e le tendenze che stanno ridisegnando il panorama tecnologico.',
    color: '#60a5fa',
    count: allPosts.filter(p => p.data.category === 'tech').length
  },
];
---

<Layout>
  <!-- ─── HERO ──────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-glow"></div>
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="mono">// dispatch from the digital frontier</span>
      </div>
      <h1 class="hero-title">
        <span class="line line-1">Esplorare</span>
        <span class="line line-2">il margine</span>
        <span class="line line-3">tecnologico</span>
      </h1>
      <p class="hero-sub">
        Riflessioni e analisi su cybersecurity, intelligenza artificiale, 
        domotica e il futuro digitale. Senza hype, con profondità.
      </p>
      <div class="hero-actions">
        <a href="#posts" class="btn-primary">
          <span>Leggi gli articoli</span>
          <span class="mono">↓</span>
        </a>
        <a href="#about" class="btn-ghost mono">about_me.md</span></a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num mono">{allPosts.length}</span>
          <span class="stat-label">articoli</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <span class="stat-num mono">4</span>
          <span class="stat-label">tematiche</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <span class="stat-num mono">∞</span>
          <span class="stat-label">curiosità</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-hint">
      <span class="mono">scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ─── FEATURED ──────────────────────────────────── -->
  {featuredPosts.length > 0 && (
    <section class="section featured-section">
      <div class="container">
        <div class="section-header">
          <div class="section-label mono">// in evidenza</div>
        </div>
        <div class="featured-grid">
          {featuredPosts.map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              slug={post.slug}
              featured={true}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ─── TOPICS ────────────────────────────────────── -->
  <section class="section" id="topics">
    <div class="container">
      <div class="section-header">
        <div class="section-label mono">// tematiche</div>
        <h2 class="section-title">Cosa trovi qui</h2>
      </div>
      <div class="topics-grid">
        {topics.map(t => (
          <a href={`#posts`} class="topic-card" style={`--topic-color: ${t.color}`}>
            <div class="topic-icon mono">{t.icon}</div>
            <div class="topic-body">
              <h3 class="topic-title">{t.title}</h3>
              <p class="topic-desc">{t.desc}</p>
            </div>
            <div class="topic-count mono">{t.count} art.</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── POSTS ─────────────────────────────────────── -->
  <section class="section" id="posts">
    <div class="container">
      <div class="section-header">
        <div class="section-label mono">// archivio</div>
        <h2 class="section-title">Tutti gli articoli</h2>
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs" id="filterTabs">
        <button class="filter-tab active" data-filter="all">Tutti</button>
        <button class="filter-tab" data-filter="cybersecurity">Cybersecurity</button>
        <button class="filter-tab" data-filter="ai">AI</button>
        <button class="filter-tab" data-filter="domotica">Domotica</button>
        <button class="filter-tab" data-filter="tech">Tech</button>
      </div>

      <div class="posts-grid" id="postsGrid">
        {sortedPosts.map(post => (
          <div class="post-item" data-category={post.data.category}>
            <PostCard
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              slug={post.slug}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ABOUT ─────────────────────────────────────── -->
  <section class="section about-section" id="about">
    <div class="container">
      <div class="about-inner">
        <div class="about-left">
          <div class="section-label mono">// about_me.md</div>
          <h2 class="section-title">Chi sono</h2>
          <p class="about-text">
            Appassionato di tecnologia, sicurezza informatica e automazione domestica. 
            Questo spazio nasce dalla necessità di documentare esplorazioni, 
            condividere pensieri e contribuire alla conversazione tecnica italiana.
          </p>
          <p class="about-text">
            Non ho risposte definitive — solo domande interessanti e la 
            curiosità di cercare. Ogni articolo è un appunto pubblico, 
            una riflessione in divenire.
          </p>
          <div class="about-tags">
            <span class="tag cybersecurity">Security researcher</span>
            <span class="tag ai">AI enthusiast</span>
            <span class="tag domotica">Home automator</span>
            <span class="tag tech">Open source advocate</span>
          </div>
        </div>
        <div class="about-right">
          <div class="terminal">
            <div class="terminal-bar">
              <span class="t-dot"></span>
              <span class="t-dot"></span>
              <span class="t-dot"></span>
              <span class="t-title mono">whoami.sh</span>
            </div>
            <div class="terminal-body">
              <p><span class="t-prompt">$</span> <span class="t-cmd">cat interests.txt</span></p>
              <p class="t-out">→ cybersecurity / offensive & defensive</p>
              <p class="t-out">→ AI / LLMs / machine learning</p>
              <p class="t-out">→ home automation / privacy-first IoT</p>
              <p class="t-out">→ open source / self-hosting</p>
              <br/>
              <p><span class="t-prompt">$</span> <span class="t-cmd">echo $STACK</span></p>
              <p class="t-out">Linux · Python · Home Assistant · Nix</p>
              <br/>
              <p><span class="t-prompt">$</span> <span class="t-cmd">cat philosophy.md</span></p>
              <p class="t-out">"Privacy is not a luxury — it's a right."</p>
              <p class="t-cursor">█</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── NEWSLETTER / CTA ──────────────────────────── -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-glow"></div>
        <div class="section-label mono">// stay connected</div>
        <h2 class="cta-title">Segui il feed RSS</h2>
        <p class="cta-sub">
          Niente newsletter, niente tracking. Solo un buon feed RSS 
          per ricevere i nuovi articoli nel tuo lettore preferito.
        </p>
        <a href="/rss.xml" class="btn-primary">
          <span>↗ Aggiungi RSS feed</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
/* ─── HERO ─────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 7rem 0 4rem;
  overflow: hidden;
}

.hero-grid-bg {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(99,202,183,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99,202,183,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
}

.hero-glow {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 800px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(99,202,183,0.05) 0%, transparent 70%);
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  margin-bottom: 2rem;
  padding: 0.4rem 1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 999px;
  color: var(--accent);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  animation: fadeUp 0.6s ease both;
}

.hero-title {
  font-size: clamp(3rem, 8vw, 6rem);
  font-weight: 300;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
}

.line {
  display: block;
  opacity: 0;
  transform: translateY(20px);
  animation: fadeUp 0.7s ease forwards;
}
.line-1 { animation-delay: 0.1s; }
.line-2 { animation-delay: 0.2s; color: var(--accent); font-style: italic; }
.line-3 { animation-delay: 0.3s; }

.hero-sub {
  max-width: 520px;
  color: var(--text-muted);
  font-size: 1.05rem;
  line-height: 1.7;
  margin-bottom: 2.5rem;
  animation: fadeUp 0.7s 0.4s ease both;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 4rem;
  animation: fadeUp 0.7s 0.5s ease both;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  background: var(--accent);
  color: var(--bg);
  font-weight: 500;
  font-size: 0.9rem;
  border-radius: var(--radius);
  transition: opacity 0.2s, transform 0.2s;
}
.btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }

.btn-ghost {
  padding: 0.75rem 1.5rem;
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 0.8rem;
  letter-spacing: 0.05em;
  border-radius: var(--radius);
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

.hero-stats {
  display: flex;
  align-items: center;
  gap: 2rem;
  animation: fadeUp 0.7s 0.6s ease both;
}

.stat { display: flex; flex-direction: column; gap: 0.2rem; }
.stat-num { font-size: 1.5rem; color: var(--text); }
.stat-label { font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; }
.stat-sep { width: 1px; height: 2rem; background: var(--border); }

.hero-scroll-hint {
  position: absolute;
  bottom: 2rem;
  right: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-dim);
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  animation: fadeIn 1s 1s ease both;
}

.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--text-dim), transparent);
  animation: scrollPulse 2s ease infinite;
}

/* ─── SECTIONS ─────────────────────────────── */
.section {
  padding: 5rem 0;
}

.section-header {
  margin-bottom: 3rem;
}

.section-label {
  color: var(--accent);
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  margin-bottom: 0.75rem;
}

.section-title {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 300;
  letter-spacing: -0.01em;
}

/* ─── FEATURED ─────────────────────────────── */
.featured-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1.5rem;
}

/* ─── TOPICS ───────────────────────────────── */
.topics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1rem;
}

.topic-card {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: start;
  gap: 1rem;
  padding: 1.5rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color 0.25s, background 0.25s;
  cursor: pointer;
}
.topic-card:hover {
  border-color: var(--topic-color, var(--accent));
  background: var(--bg-2);
}

.topic-icon {
  font-size: 1.2rem;
  color: var(--topic-color, var(--accent));
  padding-top: 2px;
}

.topic-title {
  font-size: 0.95rem;
  font-weight: 500;
  margin-bottom: 0.4rem;
  color: var(--text);
}

.topic-desc {
  font-size: 0.8rem;
  color: var(--text-muted);
  line-height: 1.5;
}

.topic-count {
  font-size: 0.7rem;
  color: var(--text-dim);
  white-space: nowrap;
}

/* ─── FILTER TABS ──────────────────────────── */
.filter-tabs {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.filter-tab {
  padding: 0.4rem 1rem;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  cursor: pointer;
  transition: all 0.2s;
}
.filter-tab:hover { border-color: var(--border-active); color: var(--text); }
.filter-tab.active {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg);
}

/* ─── POSTS GRID ───────────────────────────── */
.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.25rem;
}

.post-item {
  transition: opacity 0.3s, transform 0.3s;
}
.post-item.hidden {
  display: none;
}

/* ─── ABOUT ────────────────────────────────── */
.about-section { background: var(--bg-1); }

.about-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.about-text {
  color: var(--text-muted);
  margin-bottom: 1rem;
  font-size: 0.95rem;
}

.about-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1.5rem;
}

/* ─── TERMINAL ─────────────────────────────── */
.terminal {
  background: #080810;
  border: 1px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
  font-family: var(--font-mono);
  font-size: 0.8rem;
}

.terminal-bar {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
}

.t-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--border);
}
.t-dot:nth-child(1) { background: #ff5f57; }
.t-dot:nth-child(2) { background: #febc2e; }
.t-dot:nth-child(3) { background: #28c840; }

.t-title {
  margin-left: 0.5rem;
  color: var(--text-dim);
  font-size: 0.7rem;
}

.terminal-body {
  padding: 1.25rem;
  line-height: 1.9;
}

.t-prompt { color: var(--accent); margin-right: 0.5rem; }
.t-cmd { color: var(--text); }
.t-out { color: var(--text-muted); padding-left: 1rem; }

.t-cursor {
  display: inline-block;
  color: var(--accent);
  animation: blink 1s step-end infinite;
}

/* ─── CTA ──────────────────────────────────── */
.cta-section { border-top: 1px solid var(--border); }

.cta-inner {
  position: relative;
  text-align: center;
  max-width: 560px;
  margin: 0 auto;
}

.cta-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400px;
  height: 200px;
  background: radial-gradient(ellipse, var(--glow) 0%, transparent 70%);
  pointer-events: none;
}

.cta-title {
  font-size: 2rem;
  font-weight: 300;
  margin-bottom: 1rem;
}

.cta-sub {
  color: var(--text-muted);
  margin-bottom: 2rem;
  font-size: 0.95rem;
}

/* ─── ANIMATIONS ───────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ─── RESPONSIVE ───────────────────────────── */
@media (max-width: 768px) {
  .about-inner { grid-template-columns: 1fr; gap: 2rem; }
  .featured-grid, .posts-grid { grid-template-columns: 1fr; }
  .topics-grid { grid-template-columns: 1fr; }
  .hero-stats { gap: 1.2rem; }
}
</style>

<script>
// Filter tabs
const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
const items = document.querySelectorAll<HTMLElement>('.post-item');

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const filter = tab.dataset.filter;
    items.forEach(item => {
      const match = filter === 'all' || item.dataset.category === filter;
      item.classList.toggle('hidden', !match);
    });
  });
});
</script>
