---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'posts'> };
const { post } = Astro.props;
const { Content } = await post.render();

const date = new Date(post.data.pubDate);
const formatted = date.toLocaleDateString('it-IT', { 
  year: 'numeric', month: 'long', day: 'numeric' 
});

const categoryIcons: Record<string, string> = {
  tech: '◈', cybersecurity: '◉', ai: '◎', domotica: '◌',
};
---

<Layout title={`${post.data.title} — NEXUS`} description={post.data.description}>
  <article class="post-page">
    <div class="post-hero">
      <div class="post-hero-grid"></div>
      <div class="container">
        <a href="/" class="back-link mono">← torna alla home</a>
        <div class="post-meta">
          <span class={`tag ${post.data.category}`}>
            {categoryIcons[post.data.category]} {post.data.category}
          </span>
          <time class="mono" datetime={post.data.pubDate}>{formatted}</time>
        </div>
        <h1 class="post-hero-title">{post.data.title}</h1>
        <p class="post-hero-desc">{post.data.description}</p>
        {post.data.tags && (
          <div class="post-tags">
            {post.data.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        )}
      </div>
    </div>

    <div class="container post-content-wrap">
      <div class="post-content prose">
        <Content />
      </div>
    </div>

    <div class="container post-footer">
      <a href="/#posts" class="btn-ghost mono">← tutti gli articoli</a>
    </div>
  </article>
</Layout>

<style>
.post-page { padding-top: 5rem; }

.post-hero {
  position: relative;
  padding: 4rem 0 3rem;
  overflow: hidden;
}

.post-hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(99,202,183,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99,202,183,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  mask-image: radial-gradient(ellipse at center top, black 30%, transparent 70%);
}

.back-link {
  display: inline-block;
  margin-bottom: 2rem;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  transition: color 0.2s;
}
.back-link:hover { color: var(--accent); }

.post-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
  font-size: 0.8rem;
  color: var(--text-dim);
}

.post-hero-title {
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 300;
  letter-spacing: -0.02em;
  line-height: 1.15;
  max-width: 760px;
  margin-bottom: 1rem;
}

.post-hero-desc {
  max-width: 600px;
  color: var(--text-muted);
  font-size: 1.05rem;
  margin-bottom: 1.5rem;
}

.post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

.post-content-wrap {
  display: grid;
  grid-template-columns: 1fr min(700px, 100%) 1fr;
  padding-top: 3rem;
  padding-bottom: 3rem;
}

.prose {
  grid-column: 2;
  font-size: 1rem;
  line-height: 1.85;
  color: var(--text-muted);
}

.prose :global(h2) {
  font-size: 1.4rem;
  font-weight: 400;
  color: var(--text);
  margin: 2.5rem 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border);
}
.prose :global(h3) {
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--text);
  margin: 2rem 0 0.75rem;
}
.prose :global(p) { margin-bottom: 1.25rem; }
.prose :global(strong) { color: var(--text); font-weight: 500; }
.prose :global(em) { color: var(--accent); font-style: italic; }
.prose :global(ul), .prose :global(ol) {
  padding-left: 1.5rem;
  margin-bottom: 1.25rem;
}
.prose :global(li) { margin-bottom: 0.4rem; }
.prose :global(code) {
  font-family: var(--font-mono);
  font-size: 0.85em;
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 0.1em 0.4em;
  border-radius: 2px;
  color: var(--accent);
}
.prose :global(pre) {
  background: var(--surface) !important;
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1.25rem;
  overflow-x: auto;
  margin: 1.5rem 0;
}
.prose :global(pre code) {
  background: none;
  border: none;
  padding: 0;
  color: inherit;
}
.prose :global(blockquote) {
  border-left: 2px solid var(--accent);
  padding-left: 1.25rem;
  margin: 1.5rem 0;
  color: var(--text-muted);
  font-style: italic;
}
.prose :global(a) {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.prose :global(hr) {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2rem 0;
}

.post-footer {
  padding-bottom: 4rem;
}

.btn-ghost {
  display: inline-flex;
  padding: 0.6rem 1.25rem;
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  border-radius: var(--radius);
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
</style>
