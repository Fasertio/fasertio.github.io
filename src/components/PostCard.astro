---
interface Props {
  title: string;
  description: string;
  category: string;
  pubDate: string;
  slug: string;
  featured?: boolean;
}

const { title, description, category, pubDate, slug, featured } = Astro.props;

const categoryLabels: Record<string, string> = {
  tech: 'Tech',
  cybersecurity: 'Cybersecurity',
  ai: 'AI',
  domotica: 'Domotica',
};

const categoryIcons: Record<string, string> = {
  tech: '◈',
  cybersecurity: '◉',
  ai: '◎',
  domotica: '◌',
};

const date = new Date(pubDate);
const formatted = date.toLocaleDateString('it-IT', { year: 'numeric', month: 'short', day: 'numeric' });
---

<article class={`post-card ${featured ? 'featured' : ''}`}>
  <a href={`/posts/${slug}`} class="post-card-inner">
    <div class="post-card-top">
      <span class={`tag ${category}`}>
        <span>{categoryIcons[category]}</span>
        {categoryLabels[category]}
      </span>
      <time class="post-date mono" datetime={pubDate}>{formatted}</time>
    </div>
    <h3 class="post-title">{title}</h3>
    <p class="post-desc">{description}</p>
    <div class="post-read">
      <span class="mono">leggi →</span>
    </div>
  </a>
</article>

<style>
.post-card {
  --card-border: var(--border);
  position: relative;
  background: var(--surface);
  border: 1px solid var(--card-border);
  border-radius: var(--radius);
  transition: border-color 0.25s, transform 0.25s;
  overflow: hidden;
}

.post-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.post-card:hover {
  border-color: var(--border-active);
  transform: translateY(-2px);
}
.post-card:hover::before { opacity: 1; }

.post-card.featured {
  background: var(--bg-2);
  border-color: rgba(99,202,183,0.1);
}

.post-card-inner {
  display: block;
  padding: 1.75rem;
}

.post-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.post-date {
  font-size: 0.7rem;
  color: var(--text-dim);
}

.post-title {
  font-family: var(--font-sans);
  font-size: 1.1rem;
  font-weight: 500;
  line-height: 1.4;
  color: var(--text);
  margin-bottom: 0.6rem;
  transition: color 0.2s;
}
.post-card:hover .post-title { color: var(--accent); }

.post-desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 1.25rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-read {
  font-size: 0.75rem;
  color: var(--text-dim);
  letter-spacing: 0.05em;
  transition: color 0.2s;
}
.post-card:hover .post-read { color: var(--accent); }
</style>
